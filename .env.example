# Database configuration
DB_URL=jdbc:mysql://localhost:3306/cjp_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=root

# JWT configuration
# Secret key should be at least 256 bits (32 bytes) base64 encoded
JWT_SECRET=your_super_secret_key_which_should_be_long_enough
JWT_EXPIRATION_MS=28800000 # 8 hours in milliseconds

# Mail configuration (Resend SMTP)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key

# AWS S3 configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name
