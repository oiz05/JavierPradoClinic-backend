# Primary database configuration
DB_URL=jdbc:postgresql://host:5432/database
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true

# Optional local PostgreSQL configuration for Docker Compose profile "local-db"
# DB_URL=jdbc:postgresql://db:5432/cjp_db
# DB_USERNAME=admin
# DB_PASSWORD=password

# Optional Docker Compose PostgreSQL service configuration
POSTGRES_DB=cjp_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# JWT configuration
# Secret key should be at least 256 bits (32 bytes) base64 encoded
JWT_SECRET=your_super_secret_key_which_should_be_long_enough
JWT_EXPIRATION_MS=28800000 # 8 hours in milliseconds

# Mail configuration (Resend SMTP)
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key
MAIL_FROM=your_verified_sender@example.com
MAIL_RESET_SUBJECT=CJP - Password Reset Request

# AWS S3 configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# CORS configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://clinica-javier-prado.vercel.app
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept
CORS_ALLOW_CREDENTIALS=true

# Password reset configuration
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_PATH=/reset-password
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

# Docker Compose configuration
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=docker
